# Sanity CMS Configuration
# Get these values from your Sanity project dashboard: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SANITY_DATASET=production

# Site identity (used in SEO metadata + title templates)
NEXT_PUBLIC_SITE_NAME=Coast2c
# Optional: absolute site URL (falls back to http://localhost:3000 in dev).
# NEXT_PUBLIC_SITE_URL=https://coast2c.com

# Optional: Sanity read token (only needed for private datasets)
# SANITY_API_READ_TOKEN=your-read-token-here

# Required by scripts/seed-home.ts and scripts/sanity/* (seeding/content changes).
# Generate at https://www.sanity.io/manage/personal/project/<projectId>/api#tokens
# with Editor permissions. NEVER commit a real value.
# SANITY_API_WRITE_TOKEN=sk...

# Transactional email (Resend) — required for /api/contact and booking form submissions.
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM="Coast2c <no-reply@coast2c.com>"

# Optional social handles
# NEXT_PUBLIC_TWITTER_HANDLE=@coast2c

# Optional structured-data for an upcoming event (surfaced as schema.org Event on the home page).
# NEXT_PUBLIC_NEXT_EVENT_NAME="Live at Superbooth 2026"
# NEXT_PUBLIC_NEXT_EVENT_START_DATE=2026-05-08T20:00:00.000Z
# NEXT_PUBLIC_NEXT_EVENT_URL=https://example.com/tickets

# Optional future feature: external store URL. When set, /store redirects
# to this destination (see src/app/store/page.tsx for the scaffold).
# NEXT_PUBLIC_STORE_URL=https://coast2c.bandcamp.com
